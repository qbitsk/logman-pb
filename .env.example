# ─── Supabase ───────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── Database ────────────────────────────────────────────────
# Get these from: Supabase → Settings → Database → Connection string
# Use "Session mode" (port 5432) for the direct URL (migrations)
# Use "Transaction mode" (port 6543) for the pooled URL (app runtime)
DATABASE_URL=postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:6543/postgres
DATABASE_URL_DIRECT=postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:5432/postgres

# ─── Auth ────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-here
BETTER_AUTH_URL=http://localhost:3000

# ─── Email ───────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
